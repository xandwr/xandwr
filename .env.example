# Optional GitHub personal access token (no scopes needed for public repos).
# Raises the API rate limit from 60 to 5000 req/hr for the /projects page.
GITHUB_TOKEN=

# Spotify "Now Playing" widget on the landing page. All three are optional —
# the widget hides itself if any are missing. CLIENT_ID/SECRET come from the
# Spotify developer dashboard; REFRESH_TOKEN is minted once by running
# `node scripts/spotify-auth.mjs` (see that file's header for the steps).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
